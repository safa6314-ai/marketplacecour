<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane stylesheets="@admin.css"
            styleClass="page-root"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.AdminProfileController">

    <top>
        <VBox spacing="3.0"
              styleClass="page-heading">
            <Label text="Profil utilisateur"
                   styleClass="page-title"/>
            <Label text="Manage identity, profile picture and account security"
                   styleClass="page-subtitle"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="18.0"
              BorderPane.alignment="CENTER">

            <VBox prefWidth="280.0"
                  spacing="15.0"
                  styleClass="profile-card profile-photo-card">
                <Label text="Photo de profil"
                       styleClass="panel-title"/>

                <ImageView fx:id="ivProfileImage"
                           fitHeight="160.0"
                           fitWidth="160.0"
                           preserveRatio="true"/>

                <Button text="Changer photo"
                        onAction="#chooseProfileImage"
                        maxWidth="Infinity"
                        styleClass="primary-action-button">
                    <graphic>
                        <FontIcon iconLiteral="fas-camera"
                                  iconSize="13"/>
                    </graphic>
                </Button>

                <Button text="Supprimer photo"
                        onAction="#removeProfileImage"
                        maxWidth="Infinity"
                        styleClass="secondary-action-button"/>
            </VBox>

            <VBox maxWidth="590.0"
                  spacing="13.0"
                  HBox.hgrow="ALWAYS"
                  styleClass="profile-card">

                <GridPane hgap="18.0"
                          vgap="10.0"
                          styleClass="profile-meta">
                    <Label text="Role"
                           styleClass="meta-label"
                           GridPane.columnIndex="0"
                           GridPane.rowIndex="0"/>
                    <Label fx:id="lblRole"
                           text="ADMIN"
                           styleClass="meta-value"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="0"/>
                    <Label text="Status"
                           styleClass="meta-label"
                           GridPane.columnIndex="0"
                           GridPane.rowIndex="1"/>
                    <Label fx:id="lblStatus"
                           text="ACTIVE"
                           styleClass="meta-value"
                           GridPane.columnIndex="1"
                           GridPane.rowIndex="1"/>
                </GridPane>

                <TextField fx:id="tfUsername"
                           promptText="Username"
                           styleClass="admin-input"/>
                <TextField fx:id="tfEmail"
                           promptText="Email"
                           styleClass="admin-input"/>
                <TextField fx:id="tfFirstName"
                           promptText="First Name"
                           styleClass="admin-input"/>
                <TextField fx:id="tfLastName"
                           promptText="Last Name"
                           styleClass="admin-input"/>
                <PasswordField fx:id="pfPassword"
                               promptText="Nouveau password (laisser vide pour ne pas changer)"
                               styleClass="admin-input"/>

                <Button text="Save changes"
                        onAction="#saveProfile"
                        maxWidth="Infinity"
                        styleClass="primary-action-button">
                    <graphic>
                        <FontIcon iconLiteral="fas-save"
                                  iconSize="13"/>
                    </graphic>
                </Button>
            </VBox>
        </HBox>
    </center>
</BorderPane>
