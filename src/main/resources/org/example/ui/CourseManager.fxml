<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.controller.CourseManagerController"
            stylesheets="@course-manager.css"
            prefWidth="1280"
            prefHeight="820"
            styleClass="root-pane">

    <top>
        <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>
            <Label text="⬡" styleClass="header-logo"/>
            <VBox spacing="0">
                <Label text="Artevia" styleClass="header-title"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <ToggleButton fx:id="adminModeToggle"
                          text="Admin ON"
                          selected="true"
                          styleClass="mode-toggle mode-toggle-active"
                          onAction="#handleToggleAdminMode"/>
            <Label fx:id="statusLabel" text="Ready" styleClass="status-badge"/>
        </HBox>
    </top>

    <left>
        <HBox spacing="0">
            <VBox styleClass="nav-panel" spacing="10" prefWidth="110" minWidth="100">
                <padding><Insets top="14" right="10" bottom="14" left="10"/></padding>
                <Separator styleClass="nav-separator"/>
                <Button text="Home" styleClass="nav-item" maxWidth="Infinity"/>
                <Button text="Courses" styleClass="nav-item nav-item-active" maxWidth="Infinity"/>
                <Button text="Students" styleClass="nav-item" maxWidth="Infinity"/>
                <Button text="Reports" styleClass="nav-item" maxWidth="Infinity"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Button text="Settings" styleClass="nav-item" maxWidth="Infinity"/>
            </VBox>

            <VBox styleClass="left-panel" spacing="0" prefWidth="320" minWidth="260">
                <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="10">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Courses" styleClass="panel-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="courseCountLabel" text="0 courses" styleClass="count-chip"/>
                </HBox>

                <HBox styleClass="search-bar" alignment="CENTER_LEFT" spacing="8">
                    <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                    <TextField fx:id="courseSearchField"
                               promptText="Search courses..."
                               styleClass="search-field"
                               HBox.hgrow="ALWAYS"
                               maxWidth="Infinity"/>
                </HBox>

                <ListView fx:id="courseListView"
                          styleClass="modern-list course-list"
                          VBox.vgrow="ALWAYS">
                    <placeholder>
                        <Label text="No courses yet"/>
                    </placeholder>
                </ListView>

                <VBox styleClass="side-hint" spacing="4">
                    <padding><Insets top="12" right="14" bottom="12" left="14"/></padding>
                    <Label text="Select a course to manage its chapters." styleClass="status-label"/>
                </VBox>
            </VBox>
        </HBox>
    </left>

    <center>
        <SplitPane orientation="VERTICAL" dividerPositions="0.42" styleClass="main-split">
            <ScrollPane fitToWidth="true" styleClass="scroll-section" hbarPolicy="NEVER">
                <VBox styleClass="section-card" spacing="20">
                    <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Course Details" styleClass="section-heading"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="courseIdLabel" text="" styleClass="id-chip"/>
                    </HBox>
                    <Separator styleClass="divider"/>
                    <HBox styleClass="inline-action-bar" spacing="8" alignment="CENTER_RIGHT">
                        <Button fx:id="addCourseButton"
                                text="Add Course"
                                styleClass="btn-primary"
                                onAction="#handleAddCourse"/>
                        <Button fx:id="editCourseButton"
                                text="Edit"
                                styleClass="btn-secondary"
                                onAction="#handleEditCourse"/>
                        <Button fx:id="deleteCourseButton"
                                text="Delete"
                                styleClass="btn-danger"
                                onAction="#handleDeleteCourse"/>
                    </HBox>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="TITLE" styleClass="field-label"/>
                            <TextField fx:id="courseTitleField" promptText="Enter course title..." styleClass="field-input"/>
                        </VBox>
                        <VBox spacing="6" prefWidth="200">
                            <Label text="CATEGORY" styleClass="field-label"/>
                            <ComboBox fx:id="courseCategoryCombo" promptText="Select category" styleClass="field-combo" maxWidth="Infinity">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Java"/>
                                        <String fx:value="IA"/>
                                        <String fx:value="Web"/>
                                        <String fx:value="Electronique"/>
                                        <String fx:value="Design"/>
                                        <String fx:value="Marketing"/>
                                        <String fx:value="Business"/>
                                        <String fx:value="Langues"/>
                                        <String fx:value="General"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>
                        <VBox spacing="6" prefWidth="160">
                            <Label text="LEVEL" styleClass="field-label"/>
                            <ComboBox fx:id="courseLevelCombo" promptText="Select level" styleClass="field-combo" maxWidth="Infinity">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Debutant"/>
                                        <String fx:value="Intermediaire"/>
                                        <String fx:value="Avance"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>
                    </HBox>
                    <VBox spacing="6">
                        <Label text="DESCRIPTION" styleClass="field-label"/>
                        <TextArea fx:id="courseDescriptionArea"
                                  promptText="Describe what students will learn..."
                                  styleClass="field-textarea"
                                  prefRowCount="4"
                                  wrapText="true"/>
                    </VBox>
                </VBox>
            </ScrollPane>

            <SplitPane orientation="HORIZONTAL" dividerPositions="0.40" styleClass="inner-split">
                <VBox styleClass="section-card" spacing="0" minWidth="260">
                    <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="10">
                        <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                        <Label text="Chapters" styleClass="section-heading"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="chapterCountLabel" text="0 chapters" styleClass="count-chip"/>
                    </HBox>
                    <HBox styleClass="search-bar" alignment="CENTER_LEFT" spacing="8">
                        <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
                        <TextField fx:id="chapterSearchField"
                                   promptText="Search chapters..."
                                   styleClass="search-field"
                                   HBox.hgrow="ALWAYS"
                                   maxWidth="Infinity"/>
                    </HBox>
                    <ListView fx:id="chapterListView"
                              styleClass="modern-list chapter-list"
                              VBox.vgrow="ALWAYS">
                        <placeholder>
                            <Label text="Select a course"/>
                        </placeholder>
                    </ListView>
                    <HBox styleClass="action-bar" spacing="8" alignment="CENTER">
                        <padding><Insets top="10" right="12" bottom="10" left="12"/></padding>
                        <Button fx:id="addChapterButton"
                                text="Add"
                                styleClass="btn-primary"
                                onAction="#handleAddChapter"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"/>
                        <Button fx:id="editChapterButton"
                                text="Edit"
                                styleClass="btn-secondary"
                                onAction="#handleEditChapter"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"/>
                        <Button fx:id="deleteChapterButton"
                                text="Delete"
                                styleClass="btn-danger"
                                onAction="#handleDeleteChapter"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"/>
                    </HBox>
                </VBox>

                <ScrollPane fitToWidth="true" styleClass="scroll-section" hbarPolicy="NEVER">
                    <VBox styleClass="section-card" spacing="20">
                        <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Chapter Details" styleClass="section-heading"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="chapterIdLabel" text="" styleClass="id-chip"/>
                        </HBox>
                        <Separator styleClass="divider"/>
                        <HBox spacing="14" alignment="CENTER_LEFT">
                            <VBox spacing="6" prefWidth="60">
                                <Label text="ORDER" styleClass="field-label"/>
                                <TextField fx:id="chapterOrderField" promptText="1" styleClass="field-input field-input-sm"/>
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label text="TITLE" styleClass="field-label"/>
                                <TextField fx:id="chapterTitleField" promptText="Chapter title..." styleClass="field-input"/>
                            </VBox>
                        </HBox>
                        <VBox spacing="6">
                            <Label text="DESCRIPTION" styleClass="field-label"/>
                            <TextArea fx:id="chapterDescriptionArea"
                                      promptText="Brief chapter overview..."
                                      styleClass="field-textarea"
                                      prefRowCount="3"
                                      wrapText="true"/>
                        </VBox>
                        <VBox spacing="6" VBox.vgrow="ALWAYS">
                            <Label text="CONTENT" styleClass="field-label"/>
                            <TextArea fx:id="chapterContentArea"
                                      promptText="Full chapter content..."
                                      styleClass="field-textarea field-textarea-content"
                                      prefRowCount="10"
                                      wrapText="true"
                                      VBox.vgrow="ALWAYS"/>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT">
                            <Button fx:id="saveChapterButton"
                                    text="Save Chapter"
                                    styleClass="btn-primary btn-wide"
                                    onAction="#handleSaveChapter"/>
                        </HBox>
                        <Separator styleClass="divider"/>
                        <VBox spacing="14" styleClass="student-space">
                            <Label text="Student Space" styleClass="section-heading"/>
                            <VBox spacing="6">
                                <Label text="READ CHAPTER" styleClass="field-label"/>
                                <TextArea fx:id="userChapterContentArea"
                                          promptText="Select a chapter to read its content..."
                                          styleClass="field-textarea field-textarea-content"
                                          prefRowCount="6"
                                          editable="false"
                                          wrapText="true"/>
                            </VBox>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <VBox spacing="6" prefWidth="140">
                                    <Label text="RATE" styleClass="field-label"/>
                                    <ComboBox fx:id="ratingCombo" promptText="Rate" styleClass="field-combo" maxWidth="Infinity">
                                        <items>
                                            <FXCollections fx:factory="observableArrayList">
                                                <String fx:value="1"/>
                                                <String fx:value="2"/>
                                                <String fx:value="3"/>
                                                <String fx:value="4"/>
                                                <String fx:value="5"/>
                                            </FXCollections>
                                        </items>
                                    </ComboBox>
                                </VBox>
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label text="AVIS" styleClass="field-label"/>
                                    <TextArea fx:id="feedbackCommentArea"
                                              promptText="Write your feedback..."
                                              styleClass="field-textarea"
                                              prefRowCount="3"
                                              wrapText="true"/>
                                </VBox>
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_RIGHT">
                                <Button text="Download Chapter"
                                        styleClass="btn-secondary"
                                        onAction="#handleDownloadChapter"/>
                                <Button text="Send Avis"
                                        styleClass="btn-primary"
                                        onAction="#handleSubmitFeedback"/>
                            </HBox>
                            <VBox spacing="6">
                                <Label text="RENDU FILE" styleClass="field-label"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <TextField fx:id="renduFileField"
                                               promptText="Choose a file..."
                                               styleClass="field-input"
                                               editable="false"
                                               HBox.hgrow="ALWAYS"/>
                                    <Button text="Browse"
                                            styleClass="btn-secondary"
                                            onAction="#handleChooseRenduFile"/>
                                    <Button text="Send"
                                            styleClass="btn-primary"
                                            onAction="#handleSubmitRendu"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </SplitPane>
        </SplitPane>
    </center>
</BorderPane>
