<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="300.0" styleClass="client-plan-card" stylesheets="@../CSS/style.css" spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.SouscriptionCardController">
   <children>
      <HBox alignment="CENTER_LEFT">
         <children>
            <Label fx:id="clientLabel" styleClass="client-card-title" text="John Doe" />
            <HBox HBox.hgrow="ALWAYS" />
            <Label fx:id="statusLabel" style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-padding: 5 15; -fx-background-radius: 15; -fx-font-weight: bold; -fx-font-size: 11px;" text="ACTIVE" />
         </children>
      </HBox>
      <Label fx:id="planLabel" text="Premium Plan" styleClass="client-duration-label" style="-fx-font-size: 14px;" />
      <VBox spacing="5.0">
         <children>
            <Label text="Period:" textFill="#a58163" style="-fx-font-size: 12px;" />
            <Label fx:id="dateLabel" text="2023-01-01 to 2024-01-01" textFill="#6f4a2f" style="-fx-font-weight: bold;" />
         </children>
      </VBox>
      <HBox spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleRenew" styleClass="client-btn-primary" text="Edit" />
            <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="client-btn-secondary" style="-fx-text-fill: #e74c3c; -fx-border-color: #f5b7b1;" text="Delete" />
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </HBox>
   </children>
</VBox>
