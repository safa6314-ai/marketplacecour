<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="820.0" prefWidth="1400.0" styleClass="admin-root" stylesheets="@../CSS/style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AdminController">
   <children>
      <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- ====== SIDEBAR ====== -->
            <VBox prefWidth="240.0" styleClass="admin-sidebar">
               <children>
                  <!-- Brand -->
                  <VBox styleClass="sidebar-brand" spacing="2.0">
                     <children>
                        <Label styleClass="header-text" text="Artevia" />
                        <Label styleClass="muted-label" text="Administration" />
                     </children>
                  </VBox>

                  <!-- Navigation -->
                  <Label text="NAVIGATION" styleClass="muted-label" style="-fx-font-size: 10px; -fx-padding: 8 0 4 4;">
                     <VBox.margin><Insets top="8.0" /></VBox.margin>
                  </Label>
                  <Button fx:id="btnDashboardNav" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showDashboard" styleClass="admin-nav-active" text="Dashboard" />
                  <Button fx:id="btnAbonnementNav" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showAbonnements" styleClass="admin-nav" text="Abonnements" />
                  <Button fx:id="btnSouscriptionNav" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showSouscriptions" styleClass="admin-nav" text="Souscriptions" />

                  <Pane VBox.vgrow="ALWAYS" />

                  <!-- Switch to Client -->
                  <Separator style="-fx-padding: 8 0;" />
                  <Button alignment="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#switchToClientView" styleClass="admin-btn-primary" text="Client" />
               </children>
            </VBox>

            <!-- ====== MAIN CONTENT ====== -->
            <VBox HBox.hgrow="ALWAYS" spacing="0.0">
               <children>
                  <!-- TOPBAR -->
                  <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="admin-topbar">
                     <children>
                        <Label fx:id="modeTitle" styleClass="admin-section-title" text="Dashboard" />
                        <HBox fx:id="switchContainer" styleClass="admin-switch-container" visible="false" managed="false">
                           <children>
                              <Button fx:id="btnAbonnement" mnemonicParsing="false" onAction="#showAbonnements" styleClass="admin-switch-btn-active" text="Abonnements" />
                              <Button fx:id="btnSouscription" mnemonicParsing="false" onAction="#showSouscriptions" styleClass="admin-switch-btn" text="Souscriptions" />
                           </children>
                        </HBox>
                        
                        <Pane HBox.hgrow="ALWAYS" />
                        
                        <HBox fx:id="crudButtons" spacing="10" visible="false" managed="false">
                           <children>
                              <Button mnemonicParsing="false" onAction="#handleAdd" styleClass="admin-btn-secondary" text="＋  Open Form" />
                              <Button mnemonicParsing="false" onAction="#handleSave" styleClass="admin-btn-primary" text="💾  Save" />
                           </children>
                        </HBox>
                     </children>
                     <padding><Insets left="28.0" right="28.0" top="18.0" bottom="14.0" /></padding>
                  </HBox>

                  <!-- ===== DASHBOARD VIEW ===== -->
                  <ScrollPane fx:id="dashboardView" fitToWidth="true" styleClass="transparent-scroll" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox spacing="20.0" style="-fx-padding: 24;">
                           <children>
                              <!-- Stat Cards Row -->
                              <HBox spacing="16.0">
                                 <children>
                                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label text="📦 Total Plans" styleClass="stat-label" />
                                          <Label fx:id="statTotalPlans" text="0" styleClass="stat-value" />
                                          <Label text="Abonnements disponibles" styleClass="muted-label" style="-fx-font-size: 11px;" />
                                       </children>
                                    </VBox>
                                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label text="📋 Total Souscriptions" styleClass="stat-label" />
                                          <Label fx:id="statTotalSubs" text="0" styleClass="stat-value" />
                                          <Label text="Souscriptions enregistrées" styleClass="muted-label" style="-fx-font-size: 11px;" />
                                       </children>
                                    </VBox>
                                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label text="✅ Actives" styleClass="stat-label" />
                                          <Label fx:id="statActiveSubs" text="0" styleClass="stat-value" style="-fx-text-fill: #1a7a3a;" />
                                          <Label text="Souscriptions actives" styleClass="muted-label" style="-fx-font-size: 11px;" />
                                       </children>
                                    </VBox>
                                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label text="💰 Revenus" styleClass="stat-label" />
                                          <Label fx:id="statRevenue" text="0 DT" styleClass="stat-value" style="-fx-text-fill: #c1440e;" />
                                          <Label text="Revenus estimés total" styleClass="muted-label" style="-fx-font-size: 11px;" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>

                              <!-- Charts Row 1: Pie + Bar -->
                              <HBox spacing="16.0">
                                 <children>
                                    <VBox styleClass="panel-card" HBox.hgrow="ALWAYS" style="-fx-padding: 16;">
                                       <children>
                                          <Label text="📊 Répartition des Souscriptions" styleClass="section-title" />
                                          <PieChart fx:id="pieChart" prefHeight="280.0" legendVisible="true" labelsVisible="true" styleClass="chart-warm" />
                                       </children>
                                    </VBox>
                                    <VBox styleClass="panel-card" HBox.hgrow="ALWAYS" style="-fx-padding: 16;">
                                       <children>
                                          <Label text="💎 Prix par Abonnement" styleClass="section-title" />
                                          <BarChart fx:id="barChart" prefHeight="280.0" legendVisible="false" styleClass="chart-warm">
                                             <xAxis><CategoryAxis label="Plan" /></xAxis>
                                             <yAxis><NumberAxis label="Prix (DT)" /></yAxis>
                                          </BarChart>
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>

                              <!-- Charts Row 2: Line chart full width -->
                              <VBox styleClass="panel-card" style="-fx-padding: 16;">
                                 <children>
                                    <Label text="📈 Souscriptions par Mois" styleClass="section-title" />
                                    <LineChart fx:id="lineChart" prefHeight="260.0" legendVisible="false" styleClass="chart-warm" createSymbols="true">
                                       <xAxis><CategoryAxis label="Mois" /></xAxis>
                                       <yAxis><NumberAxis label="Nombre" /></yAxis>
                                    </LineChart>
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </content>
                  </ScrollPane>

                  <!-- ===== GRID VIEW (Abonnements / Souscriptions) ===== -->
                  <HBox fx:id="gridView" spacing="16.0" VBox.vgrow="ALWAYS" visible="false" managed="false">
                     <children>
                        <VBox HBox.hgrow="ALWAYS" spacing="16.0">
                           <children>
                              <!-- Search & Filters moved to Content Area -->
                              <HBox fx:id="filterContainer" alignment="CENTER_LEFT" spacing="12.0" style="-fx-padding: 10 24 0 24;">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" styleClass="search-box">
                                       <children>
                                          <Label text="🔍" style="-fx-padding: 0 0 0 10;"/>
                                          <TextField fx:id="searchField" promptText="Rechercher par nom..." styleClass="transparent-tf" prefWidth="250.0" />
                                       </children>
                                    </HBox>
                                    <ComboBox fx:id="filterCombo" promptText="Filtrer par..." prefWidth="180.0" styleClass="admin-combo" />
                                 </children>
                              </HBox>

                              <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
                                 <content>
                                    <GridPane fx:id="grid" hgap="20.0" vgap="20.0">
                                       <padding><Insets bottom="24.0" left="24.0" right="24.0" top="10.0" /></padding>
                                    </GridPane>
                                 </content>
                              </ScrollPane>
                           </children>
                        </VBox>

                        <!-- FORM PANEL -->
                        <VBox fx:id="formPanel" managed="false" prefWidth="380.0" spacing="12.0" styleClass="admin-form-panel" visible="false">
                           <children>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label styleClass="admin-section-title" text="Formulaire" />
                                    <Pane HBox.hgrow="ALWAYS" />
                                    <Button mnemonicParsing="false" onAction="#handleCloseForm" styleClass="admin-btn-secondary" text="✕  Close" />
                                 </children>
                              </HBox>

                              <!-- Abonnement Form -->
                              <VBox fx:id="abonnementForm" spacing="6.0">
                                 <children>
                                    <Label text="Nom" styleClass="form-field-label" />
                                    <TextField fx:id="aboNomField" promptText="Basic / Premium / VIP" />
                                    <Label fx:id="aboNomError" styleClass="error-label" />

                                    <Label text="Prix" styleClass="form-field-label" />
                                    <TextField fx:id="aboPrixField" promptText="ex: 29.90" />
                                    <Label fx:id="aboPrixError" styleClass="error-label" />

                                    <Label text="Durée (mois)" styleClass="form-field-label" />
                                    <TextField fx:id="aboDureeField" promptText="ex: 6" />
                                    <Label fx:id="aboDureeError" styleClass="error-label" />

                                    <Label text="Description" styleClass="form-field-label" />
                                    <TextArea fx:id="aboDescField" prefRowCount="3" />
                                    <Label fx:id="aboDescError" styleClass="error-label" />
                                 </children>
                              </VBox>

                              <!-- Souscription Form -->
                              <VBox fx:id="souscriptionForm" managed="false" spacing="6.0" visible="false">
                                 <children>
                                    <Label text="Nom Client" styleClass="form-field-label" />
                                    <TextField fx:id="subClientField" promptText="ex: Ali" />
                                    <Label fx:id="subClientError" styleClass="error-label" />

                                    <Label text="Date Début" styleClass="form-field-label" />
                                    <DatePicker fx:id="subDateDebut" maxWidth="1.7976931348623157E308" />
                                    <Label fx:id="subDateDebutError" styleClass="error-label" />

                                    <Label text="Date Fin" styleClass="form-field-label" />
                                    <DatePicker fx:id="subDateFin" maxWidth="1.7976931348623157E308" />
                                    <Label fx:id="subDateFinError" styleClass="error-label" />

                                    <Label text="Statut" styleClass="form-field-label" />
                                    <TextField fx:id="subStatutField" promptText="active / inactive" />
                                    <Label fx:id="subStatutError" styleClass="error-label" />

                                    <Label text="Abonnement" styleClass="form-field-label" />
                                    <ComboBox fx:id="subAboComboBox" promptText="Choisir un abonnement" maxWidth="1.7976931348623157E308" />
                                    <Label fx:id="subAboIdError" styleClass="error-label" />
                                 </children>
                              </VBox>
                           </children>
                           <padding><Insets top="20.0" right="20.0" left="20.0" bottom="20.0" /></padding>
                        </VBox>
                     </children>
                     <VBox.margin><Insets left="8.0" right="16.0" bottom="16.0" /></VBox.margin>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
