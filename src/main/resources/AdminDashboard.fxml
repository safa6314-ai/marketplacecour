<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="760.0" prefWidth="1180.0" styleClass="app-root" stylesheets="@quiz-theme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AdminDashboardController">
   <left>
      <VBox prefWidth="260.0" spacing="18.0" styleClass="sidebar">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
               <children>
                  <Label styleClass="logo-mark" text="A" />
                  <Label styleClass="brand-title" text="ARTEVIA QUIZ" />
               </children>
            </HBox>
            <Label styleClass="sidebar-kicker" text="NAVIGATION" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="nav-btn-active" text="Tableau de bord" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#allerVersQuestions" styleClass="nav-btn" text="Questions" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#allerVersReponses" styleClass="nav-btn" text="Reponses" />
            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#allerVersUtilisateur" styleClass="switch-btn" text="Passer en Utilisateur" />
            <VBox spacing="6.0" styleClass="path-card">
               <children>
                  <Label styleClass="path-title" text="Parcours de creation" />
                  <Label styleClass="path-text" text="Question -&gt; Reponses" />
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="28.0" left="28.0" right="24.0" top="32.0" />
         </padding>
      </VBox>
   </left>
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll">
         <content>
            <VBox spacing="24.0" styleClass="content-page">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="14.0">
                     <children>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="page-title" text="Tableau de bord" />
                              <Label styleClass="page-subtitle" text="Vue d'ensemble du contenu et du parcours de creation." />
                           </children>
                        </VBox>
                        <Button mnemonicParsing="false" onAction="#allerVersQuestions" styleClass="primary-btn" text="Nouvelle Question" />
                     </children>
                  </HBox>

                  <HBox spacing="18.0">
                     <children>
                        <VBox spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="stat-label" text="Questions" />
                              <Label fx:id="lblQuestions" styleClass="stat-value" text="0" />
                           </children>
                        </VBox>
                        <VBox spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="stat-label" text="Reponses" />
                              <Label fx:id="lblReponses" styleClass="stat-value" text="0" />
                           </children>
                        </VBox>
                        <VBox spacing="8.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                           <children>
                              <Label styleClass="stat-label" text="Categories" />
                              <Label fx:id="lblCategories" styleClass="stat-value" text="0" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <VBox spacing="18.0" styleClass="panel">
                     <children>
                        <Label styleClass="page-title-small" text="Parcours de creation" />
                        <GridPane hgap="18.0" vgap="18.0">
                           <children>
                              <VBox spacing="8.0" styleClass="step-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                 <children>
                                    <Label styleClass="step-number" text="01" />
                                    <Label styleClass="step-title" text="Creer les questions" />
                                    <Label styleClass="step-text" text="Definir le contenu, la categorie et le niveau." wrapText="true" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" styleClass="step-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                 <children>
                                    <Label styleClass="step-number" text="02" />
                                    <Label styleClass="step-title" text="Ajouter les reponses" />
                                    <Label styleClass="step-text" text="Associer les choix a chaque question." wrapText="true" />
                                 </children>
                              </VBox>
                              <VBox spacing="8.0" styleClass="step-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                 <children>
                                    <Label styleClass="step-number" text="03" />
                                    <Label styleClass="step-title" text="Marquer les bonnes reponses" />
                                    <Label styleClass="step-text" text="Une question peut avoir une ou plusieurs bonnes reponses." wrapText="true" />
                                 </children>
                              </VBox>
                           </children>
                        </GridPane>
                     </children>
                     <padding>
                        <Insets bottom="26.0" left="28.0" right="28.0" top="26.0" />
                     </padding>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="34.0" left="38.0" right="38.0" top="34.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
