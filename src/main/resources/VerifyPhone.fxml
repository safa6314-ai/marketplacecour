<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="430.0"
      spacing="14.0"
      styleClass="signin-card"
      stylesheets="@signin.css"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.VerifyPhoneController">

    <children>
        <Label text="Verification telephone" styleClass="signin-title" />
        <Label text="Un code OTP a ete envoye au numero suivant :"
               styleClass="signin-subtitle" />
        <Label fx:id="lblPhone"
               text="+216"
               styleClass="phone-valid-label" />

        <TextField fx:id="tfCode"
                   promptText="Code OTP"
                   styleClass="form-control" />

        <Label fx:id="lblMessage"
               styleClass="popup-error-label" />

        <HBox spacing="10.0" styleClass="actions-row">
            <Button text="Verifier"
                    onAction="#verifyCode"
                    prefWidth="140.0"
                    styleClass="primary-button" />
            <Button text="Renvoyer"
                    onAction="#resendCode"
                    prefWidth="130.0"
                    styleClass="secondary-button" />
            <Button text="Annuler"
                    onAction="#cancel"
                    prefWidth="110.0"
                    styleClass="secondary-button" />
        </HBox>
    </children>
</VBox>

