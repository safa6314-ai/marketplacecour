<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="560.0" prefWidth="640.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AjouterEvenement"
            styleClass="page-root">
   <children>

      <!-- Panel Card principal -->
      <VBox layoutX="30.0" layoutY="20.0"
            prefWidth="580.0"
            styleClass="panel-card"
            spacing="16.0">
         <children>

            <!-- Titre -->
            <Label text="Ajouter un Événement"
                   styleClass="panel-title" />

            <!-- Titre -->
            <HBox spacing="12.0" alignment="CENTER_LEFT">
               <Label text="Titre *" styleClass="topbar-subtitle" prefWidth="120.0"/>
               <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                  <TextField fx:id="tfTitre"
                             promptText="Min 3 caractères"
                             styleClass="admin-input"
                             prefWidth="300.0"/>
                  <Label fx:id="lblErrTitre" styleClass="topbar-role"/>
               </VBox>
            </HBox>

            <!-- Date Début -->
            <HBox spacing="12.0" alignment="CENTER_LEFT">
               <Label text="Date Début *" styleClass="topbar-subtitle" prefWidth="120.0"/>
               <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                  <DatePicker fx:id="dpDateDebut"
                              styleClass="admin-date"
                              prefWidth="220.0"/>
                  <Label fx:id="lblErrDateDebut" styleClass="topbar-role"/>
               </VBox>
            </HBox>

            <!-- Date Fin -->
            <HBox spacing="12.0" alignment="CENTER_LEFT">
               <Label text="Date Fin *" styleClass="topbar-subtitle" prefWidth="120.0"/>
               <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                  <DatePicker fx:id="dpDateFin"
                              styleClass="admin-date"
                              prefWidth="220.0"/>
                  <Label fx:id="lblErrDateFin" styleClass="topbar-role"/>
               </VBox>
            </HBox>

            <!-- Lieu -->
            <HBox spacing="12.0" alignment="CENTER_LEFT">
               <Label text="Lieu *" styleClass="topbar-subtitle" prefWidth="120.0"/>
               <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                  <TextField fx:id="tfLieu"
                             promptText="Entrez le lieu"
                             styleClass="admin-input"
                             prefWidth="300.0"/>
                  <Label fx:id="lblErrLieu" styleClass="topbar-role"/>
               </VBox>
            </HBox>

            <!-- Capacité -->
            <HBox spacing="12.0" alignment="CENTER_LEFT">
               <Label text="Capacité *" styleClass="topbar-subtitle" prefWidth="120.0"/>
               <Spinner fx:id="spCapacite" prefWidth="120.0" prefHeight="40.0"/>
               <Label text="personnes" styleClass="topbar-subtitle"/>
            </HBox>

            <!-- Type -->
            <HBox spacing="12.0" alignment="CENTER_LEFT">
               <Label text="Type *" styleClass="topbar-subtitle" prefWidth="120.0"/>
               <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                  <ComboBox fx:id="cbType"
                            promptText="Choisir un type"
                            styleClass="admin-combo"
                            prefWidth="220.0"/>
                  <Label fx:id="lblErrType" styleClass="topbar-role"/>
               </VBox>
            </HBox>

            <!-- Statut -->
            <HBox spacing="12.0" alignment="CENTER_LEFT">
               <Label text="Statut" styleClass="topbar-subtitle" prefWidth="120.0"/>
               <CheckBox fx:id="cbStatut" text="Planifié"/>
            </HBox>

            <!-- Message erreur global -->
            <Label fx:id="lblErrGlobal"
                   prefWidth="500.0"
                   styleClass="topbar-role"/>

            <!-- Boutons -->
            <HBox spacing="12.0" alignment="CENTER_RIGHT">
               <Button text="Se déconnecter"
                       onAction="#deconnexion"
                       prefWidth="130.0"
                       styleClass="secondary-action-button"/>
               <Button text="Vider"
                       onAction="#viderChamps"
                       prefWidth="100.0"
                       styleClass="secondary-action-button"/>
               <Button text="Voir les événements"
                       onAction="#voirEvenements"
                       prefWidth="180.0"
                       styleClass="danger-action-button"/>
               <Button text="Ajouter"
                       onAction="#ajouterEvent"
                       prefWidth="130.0"
                       styleClass="primary-action-button"/>
            </HBox>

         </children>
      </VBox>

   </children>
</AnchorPane>
