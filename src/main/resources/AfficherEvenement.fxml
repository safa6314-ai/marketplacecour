<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="650.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AfficherEvenement"
            styleClass="admin-shell"
            stylesheets="@styles.css">

    <children>

        <!-- Titre -->
        <Label layoutX="30.0" layoutY="20.0"
               text="Liste des Événements"
               styleClass="page-title" />

        <!-- Filter Bar -->
        <AnchorPane layoutX="30.0" layoutY="60.0"
                    prefWidth="1040.0" prefHeight="100.0"
                    styleClass="filter-bar">

            <!-- Recherche -->
            <Label layoutX="15.0" layoutY="15.0"
                   text="Rechercher :"
                   styleClass="form-field-label" />

            <TextField fx:id="tfRecherche"
                       layoutX="100.0" layoutY="10.0"
                       prefWidth="250.0"
                       promptText="Rechercher par titre..."
                       onKeyReleased="#rechercherEvent"
                       styleClass="admin-input" />

            <Button layoutX="365.0" layoutY="10.0"
                    text="Rechercher"
                    onAction="#rechercherEvent"
                    prefWidth="110.0"
                    styleClass="primary-action-button" />

            <Button layoutX="490.0" layoutY="10.0"
                    text="Tout afficher"
                    onAction="#chargerDonnees"
                    prefWidth="110.0"
                    styleClass="secondary-action-button" />

            <!-- Filtre et Tri -->
            <Label layoutX="15.0" layoutY="60.0"
                   text="Filtrer par type :"
                   styleClass="form-field-label" />

            <ComboBox fx:id="cbFiltreType"
                      layoutX="130.0" layoutY="55.0"
                      prefWidth="160.0"
                      promptText="Tous les types"
                      onAction="#filtrerParType"
                      styleClass="admin-combo" />

            <Label layoutX="330.0" layoutY="60.0"
                   text="Trier par :"
                   styleClass="form-field-label" />

            <ComboBox fx:id="cbTri"
                      layoutX="400.0" layoutY="55.0"
                      prefWidth="200.0"
                      onAction="#trierTable"
                      styleClass="admin-combo" />

            <!-- Compteur -->
            <Label fx:id="lblCompteur"
                   layoutX="850.0" layoutY="60.0"
                   styleClass="compteur-label" />

        </AnchorPane>

        <!-- TableView -->
        <TableView fx:id="tableEvent"
                   layoutX="30.0" layoutY="175.0"
                   prefHeight="400.0" prefWidth="1040.0"
                   styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId"        text="ID"         prefWidth="50.0" />
                <TableColumn fx:id="colTitre"     text="Titre"      prefWidth="220.0" />
                <TableColumn fx:id="colDateDebut" text="Date Début" prefWidth="150.0" />
                <TableColumn fx:id="colDateFin"   text="Date Fin"   prefWidth="150.0" />
                <TableColumn fx:id="colLieu"      text="Lieu"       prefWidth="130.0" />
                <TableColumn fx:id="colCapacite"  text="Capacité"   prefWidth="80.0" />
                <TableColumn fx:id="colType"      text="Type"       prefWidth="100.0" />
                <TableColumn fx:id="colStatut"    text="Statut"     prefWidth="120.0" />
            </columns>
        </TableView>

        <!-- Boutons d'action -->
        <HBox layoutX="30.0" layoutY="595.0" spacing="15.0">
            <Button text="✏ Modifier"
                    onAction="#ouvrirModifier"
                    prefWidth="140.0" prefHeight="38.0"
                    styleClass="primary-action-button" />

            <Button text="🗑 Supprimer"
                    onAction="#supprimerEvent"
                    prefWidth="140.0" prefHeight="38.0"
                    styleClass="danger-action-button" />

            <Button text="↩ Retour à l'ajout"
                    onAction="#retourAjout"
                    prefWidth="170.0" prefHeight="38.0"
                    styleClass="secondary-action-button" />
        </HBox>

    </children>
</AnchorPane>