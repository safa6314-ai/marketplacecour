<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="680.0" prefWidth="1000.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AfficherEvenement"
            styleClass="page-root">
    <children>

        <VBox layoutX="20.0" layoutY="15.0"
              prefWidth="960.0"
              spacing="14.0">
            <children>

                <!-- ── Titre ── -->
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="Liste des Événements" styleClass="page-title"/>
                    <Label fx:id="lblCompteur" styleClass="topbar-subtitle"/>
                    <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#toggleDarkMode" styleClass="secondary-action-button" text="🌙" style="-fx-font-size: 16px;"/>
                </HBox>

                <!-- ── Barre filtre / recherche ── -->
                <HBox styleClass="filter-bar" spacing="12.0" alignment="CENTER_LEFT">
                    <HBox styleClass="search-box" alignment="CENTER_LEFT" prefWidth="260.0">
                        <TextField fx:id="tfRecherche"
                                   promptText="Rechercher par titre ou lieu..."
                                   styleClass="search-input"
                                   prefWidth="240.0"
                                   onKeyReleased="#rechercherEvent"/>
                    </HBox>

                    <Label text="Type :" styleClass="topbar-subtitle"/>
                    <ComboBox fx:id="cbFiltreType"
                              prefWidth="160.0"
                              styleClass="admin-combo"
                              onAction="#filtrerParType"/>

                    <Label text="Trier par :" styleClass="topbar-subtitle"/>
                    <ComboBox fx:id="cbTri"
                              prefWidth="200.0"
                              styleClass="admin-combo"
                              onAction="#trierTable"/>

                    <Button text="Tout afficher"
                            onAction="#chargerDonnees"
                            styleClass="secondary-action-button"
                            prefWidth="120.0"/>
                </HBox>

                <!-- ── En-tête colonnes ── -->
                <HBox styleClass="panel-card" spacing="0.0"
                      prefWidth="960.0" minHeight="38.0">
                    <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
                    <Label text="ID"          prefWidth="55.0"  styleClass="topbar-subtitle"/>
                    <Label text="Titre"       prefWidth="190.0" styleClass="topbar-subtitle"/>
                    <Label text="Date Début"  prefWidth="130.0" styleClass="topbar-subtitle"/>
                    <Label text="Date Fin"    prefWidth="130.0" styleClass="topbar-subtitle"/>
                    <Label text="Lieu"        prefWidth="120.0" styleClass="topbar-subtitle"/>
                    <Label text="Capacité"    prefWidth="80.0"  styleClass="topbar-subtitle"/>
                    <Label text="Type"        prefWidth="110.0" styleClass="topbar-subtitle"/>
                    <Label text="Statut"      prefWidth="95.0"  styleClass="topbar-subtitle"/>
                </HBox>

                <!-- ── Liste scrollable ── -->
                <ScrollPane fx:id="scrollPane"
                            prefHeight="290.0" prefWidth="960.0"
                            fitToWidth="true" hbarPolicy="NEVER">
                    <content>
                        <VBox fx:id="vboxListeEvents" spacing="4.0" prefWidth="940.0">
                            <padding><Insets top="6" right="6" bottom="6" left="6"/></padding>
                        </VBox>
                    </content>
                </ScrollPane>

                <!-- ── Boutons d'action ── -->
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <children>
                        <Button text="📝 Modifier"
                                onAction="#ouvrirModifier"
                                prefWidth="150.0"
                                styleClass="primary-action-button"/>
                        <Button text="❌ Supprimer"
                                onAction="#supprimerEvent"
                                prefWidth="150.0"
                                styleClass="danger-action-button"/>
                        <Button text="➕ Ajouter"
                                onAction="#retourAjout"
                                prefWidth="150.0"
                                styleClass="secondary-action-button"/>
                        <Button text="🚪 Quitter"
                                onAction="#deconnexion"
                                prefWidth="150.0"
                                styleClass="secondary-action-button"/>
                    </children>
                </HBox>

            </children>
        </VBox>

    </children>
</AnchorPane>
