<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="420.0"
      spacing="14.0"
      styleClass="signin-card"
      stylesheets="@signin.css"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.ForgotPasswordController">

    <children>
        <Label text="Forgot Password" styleClass="signin-title" />
        <Label text="Saisissez votre email pour recevoir un code OTP."
               styleClass="signin-subtitle" />

        <TextField fx:id="tfEmail"
                   promptText="Email"
                   styleClass="form-control" />

        <Label fx:id="lblMessage"
               styleClass="popup-error-label" />

        <HBox spacing="12.0" styleClass="actions-row">
            <Button text="Envoyer le code"
                    onAction="#sendCode"
                    prefWidth="190.0"
                    styleClass="primary-button" />
            <Button text="Annuler"
                    onAction="#cancel"
                    prefWidth="150.0"
                    styleClass="secondary-button" />
        </HBox>
    </children>
</VBox>

