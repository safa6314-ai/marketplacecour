<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox prefWidth="300.0" styleClass="card" stylesheets="@../css/style.css" spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AbonnementCardController">
   <children>
      <Label fx:id="nameLabel" styleClass="card-title" text="Premium Plan" />
      <HBox alignment="BASELINE_LEFT" spacing="6.0">
         <children>
            <Label fx:id="priceLabel" styleClass="card-price" text="99.99" />
            <Label text="DT / month" styleClass="card-unit-label" />
         </children>
      </HBox>
      <Label fx:id="durationLabel" styleClass="client-duration-label" text="12 Months" />
      <Label fx:id="descLabel" styleClass="card-desc" text="Unlock all features including exclusive artist auctions and 0% commission." wrapText="true" VBox.vgrow="ALWAYS" />
      <Pane styleClass="card-divider">
         <VBox.margin><Insets top="4.0" bottom="4.0" /></VBox.margin>
      </Pane>
      <HBox spacing="10.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleEdit" styleClass="card-edit-btn" text="✏  Edit" />
            <Button mnemonicParsing="false" onAction="#handleDelete" styleClass="card-delete-btn" text="🗑  Delete" />
         </children>
      </HBox>
   </children>
</VBox>
